BROWSER_PATH=C:\path\to\instrumented\browser.exe
BROWSER_KIND=chromium

OUT_DIR=out
CRASH_DIR=crashes
# CORPUS_DIR=corpus\seeds # optional

ITERATION_TIMEOUT_MS=12000
ACTION_TIMEOUT_MS=300
PAGE_READY_TIMEOUT_MS=120
POST_ACTIONS_SETTLE_MS=120
INTER_ACTION_DELAY_MS=10

SEED_INPUTS=1
SEED_ACTIONS=6
MAX_ACTIONS=48
MAX_ITERATIONS=0

DISABLE_BREAKPAD=true
